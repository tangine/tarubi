{% doc %}

@param {boolean} show_secondary_image - Show the secondary image on hover. Default: false (optional)
@param {boolean} show_rating - Show the product rating. Default: false
@param {boolean} show_vendor - Show the product vendor. Default: false

{% enddoc %}

<div class="product-card relative card" data-available="{{ product.available }}" data-product-id="{{ product.id }}">
  <a class="product-card__image" href="{{ product.url }}" title="{{ product.title | escape }}">
    <img src="{{ product.featured_image |  image_url }}" alt="{{ product.featured_image_alt }}">
    {% if product.image[1] != null %}
      <img src="{{ product.images[1] | image_url }}" alt="">
    {% endif %}
  </a>
  <div class="product-card__title" title="{{ product.title | escape }}">{{ product.title | escape }}</div>
  <div class="product-card__price">
    <div class="sale-price">{{ product.price | money }}</div>
    {% if product.compare_at_price != blank %}
      <div class="regular-price">{{ product.compare_at_price | money }}</div>
    {% endif %}
  </div>
  {% if show_vendor %}
    <div class="product-card__vendor">{{ product.vendor }}</div>
  {% endif %}
</div>
