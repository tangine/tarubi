{% doc %}
{% enddoc %}

<div class="product-card" data-available="{{ product.available }}" data-product-id="{{ product.id }}">
  <div class="product-card__media">
    <img src="{{ product.featured_image |  image_url }}" alt="{{ product.featured_image_alt }}">
  </div>
  <div>{{ product.title }}</div>
  <div class="product-card__price">
    <div class="price-regular">{{ product.compare_at_price | money }}</div>
    <div class="price-sale">{{ product.price | money }}</div>
  </div>
</div>

{% style %}
  .product-card{cursor:pointer;}
  .product-card__media{width: 100%; aspect-ratio:1;overflow:hidden;}
  .product-card__media img{width: 100%; height:100%;object-fit:contain;transition:all 0.3s ease-in-out}
  .product-card__media img:hover{transform:scale(1.1);}
  .product-card .product-card__price{display:flex;flex-direction:row;}
  .product-card .product-card__price .price-regular{text-decoration:line-through;}
{% endstyle %}