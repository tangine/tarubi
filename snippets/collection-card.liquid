{% doc %}
{% enddoc %}

<div class="collection-card" data-collection-id="{{ collection.id }}">
  <div class="collection-card__media">
    <img src="{{ collection.featured_image |  image_url }}" alt="{{ collection.featured_image_alt }}">
  </div>
  <div class="collection-card__title">{{ collection.title }}</div>
  <div class="collection-card__description">{{ collection.description }}</div>
</div>

{% stylesheet %}
  .collection-card{cursor:pointer;overflow:hidden;box-shadow: 0 0 5px gray;border-radius: 10px;}
  .collection-card__media{width: 100%; aspect-ratio:1;overflow:hidden;}
  .collection-card__media img{width: 100%; height:100%;object-fit:contain;transition:all 0.3s ease-in-out}
  .collection-card__media img:hover{transform:scale(1.1);}
  .collection-card .collection-card__price{display:flex;flex-direction:row;}
  .collection-card .collection-card__price .price-regular{text-decoration:line-through;}
{% endstylesheet %}