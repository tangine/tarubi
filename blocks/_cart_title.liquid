<div class="cart-title">
  <h1 class="{{ block.settings.alignment }}">
    {%- if cart.empty? or force_empty -%}
      {{ 'content.your_cart_is_empty' | t }}
    {%- else -%}
      {{ 'content.cart_title' | t }}
      {% comment %}{%- if block_settings.show_count -%}{% render 'cart-bubble' %}{%- endif -%}{% endcomment %}
    {%- endif -%}
  </h1>
</div>

{% schema %}
{
  "name": "t:names.cart_title",
  "settings": [
    {
      "type":"select",
      "id": "alignment",
      "label": "t:settings.alignment",
      "default": "text-center",
      "options": [
        {
          "value": "text-left",
          "label": "t:options.left"
        },
        {
          "value": "text-center",
          "label": "t:options.center"
        },
        {
          "value": "text-right",
          "label": "t:options.right"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:names.cart_title"
    }
  ]
}
{% endschema %}