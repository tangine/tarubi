<div class="cart">
  {% content_for 'blocks' %}
  <div>
    {% for item in cart.items %}
      <div class="cart-product-item">
        <a class="cart-product__media" href="{{ item.url }}">
          <img src="{{ item.image | image_url  }}" alt="" />
        </a>
        <div class="cart-product__info">
          <div class="cart-product__title">{{ item.title }}</div>
          <div class="cart-product__title">{{ item.product.title }}</div>
          <div class="cart-product__variants">
            {% for variant in item.variant.options %}
              {% if forloop.index != 1 %}
                ,
              {% endif %}
              {{ variant }}
            {% endfor %}
            {% comment %}{{ item.variant | json }}{% endcomment %}
          </div>
          <div class="cart-product__price">{{ item.price }}</div>
          <div class="cart-product__quantity">{{ item.quantity }}</div>
        </div>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "t:names.cart",
  "settings": [],
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "_cart_title"
    }
  ],
  "presets": [
    {
      "name": "t:names.cart"
    }
  ]
}
{% endschema %}

{% stylesheet %}
.cart-product-item{display:flex;flex-direction:row;}
.cart-product-item .cart-product__media{display:block;width:200px;aspect-ration:0;overflow:hidden;}
.cart-product-item .cart-product__media img{width:100%;height:100%;object-fit:contain;}
{% endstylesheet %}