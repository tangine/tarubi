{% if section.settings.visible %}
  <section id="{{ section.id }}" class="section {{ section.settings.container_type }} {{ section.class }} {{ section.extra_style }}">
    {% for link in linklists[section.settings.menu].links %}
      <div>
        <a href="{{ link.url }}">{{ link.title }}</a>
      </div>
    {% endfor %}
    <div class="copyright">
      {{ settings.copyright }}
    </div>
    {% if customer %}
      <script>
        window.ShopifyCustomer = {
          id: "{{ customer.id }}",
          email: "{{ customer.email }}",
          firstName: "{{ customer.first_name }}",
          lastName: "{{ customer.last_name }}",
        }
      </script>
    {% endif %}
  </section>
{% endif %}

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "checkbox",
      "id": "visible",
      "default": true,
      "label": "t:settings.visibility"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "footer"
    },
    {
      "type": "select",
      "id": "container_type",
      "label": "t:settings.section_width",
      "default": "tarubi-container",
      "options": [
        {
          "value": "w-full",
          "label": "t:options.full"
        },
        {
          "value": "tarubi-container",
          "label": "t:options.default"
        }
      ]
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}