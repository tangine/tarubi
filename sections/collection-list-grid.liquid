<section id="{{ section.id }}" class="section collection {{ section.settings.container_type }}">
  <div  class="product-grid grid">
    {% for collection in collections %}
      <a class="product-card" href="{{ collection.url }}">
        <div class="product-card__image">
          <img src="{{ collection.featured_image | image_url }}" alt="{{ collection.title }}">
        </div>
        <div class="product-card__title">{{ collection.title }}</div>
      </a>

    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Product List",
  "settings": [
    {
      "type": "select",
      "id": "container_type",
      "label": "Section Width",
      "default": "container-fluid",
      "options": [
        {
          "value": "container-fluid",
          "label": "Full Width"
        },
        {
          "value": "container-xs",
          "label": "Max 640px"
        },
        {
          "value": "container-sm",
          "label": "Max 768px"
        },
        {
          "value": "container-md",
          "label": "Max 1024px"
        },
        {
          "value": "container-lg",
          "label": "Max 1280px"
        },
        {
          "value": "container-xl",
          "label": "Max 1440px"
        },
        {
          "value": "container-2xl",
          "label": "Max 1600px"
        },
        {
          "value": "container-3xl",
          "label": "Max 1920px"
        }
      ]
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Product List"
    }
  ]
}
{% endschema %}