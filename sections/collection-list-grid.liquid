<section id="{{ section.id }}" class="section collection {{ section.settings.container_type }}">
  <div  class="product-grid grid">
    {% for collection in collections %}
      {% comment %}<a class="product-card" href="{{ collection.url }}">{% endcomment %}
        {% comment %}<div class="product-card__image">{% endcomment %}
          {% comment %}<img src="{{ collection.featured_image | image_url }}" alt="{{ collection.title }}">{% endcomment %}
        {% comment %}</div>{% endcomment %}
        {% comment %}<div class="product-card__title">{{ collection.title }}</div>{% endcomment %}
      {% comment %}</a>{% endcomment %}

      {% render 'collection-card', collection: collection %}

    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Product List",
  "settings": [
    {
      "type": "select",
      "id": "container_type",
      "label": "t:settings.section_width",
      "default": "tarubi-container",
      "options": [
        {
          "value": "w-full",
          "label": "t:options.full"
        },
        {
          "value": "tarubi-container",
          "label": "t:options.default"
        }
      ]
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Product List"
    }
  ]
}
{% endschema %}