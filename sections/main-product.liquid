<section id="{{ section.id }}" class="section-wrapper">
<div class="section section-product {{ section.settings.container_type }}">
  <div class="product-media"></div>
  <div class="product-info">
    <div class="product-info__vendor">{{ product.vendor }}</div>
    <div class="product-info__title">{{ product.title }}</div>
    <div class="product-info__price">{{ product.price | money }}</div>
    <div class="product-info__old-price">{{ product.compare_at_price }}</div>
  </div>
</div>
</section>


{% stylesheet %}
.section-product {
display: grid;
grid-template-columns: repeat(2,1fr);
gap: 10px;
}
@media screen {max-width: 762px} {
.section-product {
grid-template-columns: 1fr;
}
}
{% endstylesheet %}
{% schema %}
{
  "name": "t:names.product",
  "settings": [
    {
      "type": "select",
      "id": "container_type",
      "label": "t:settings.section_width",
      "default": "tarubi-container",
      "options": [
        {
          "value": "w-full",
          "label": "t:options.full"
        },
        {
          "value": "tarubi-container",
          "label": "t:options.default"
        }
      ]
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "t:names.product"
    }
  ]
}
{% endschema %}