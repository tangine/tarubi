<section id="{{ section.id }}" class="section collection"
         style="padding-top:{{ section.settings.padding_top | append: 'px' }};padding-bottom:{{ section.settings.padding_bottom | append: 'px' }};">
  <div  class="collection-grid {{ section.settings.container_type }}">
    {% for collection in collections %}
      {% render 'collection-card', collection: collection %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "t:names.collection_list",
  "settings": [
    {
      "type": "select",
      "id": "container_type",
      "label": "t:settings.section_width",
      "default": "tarubi-container",
      "options": [
        {
          "value": "w-full",
          "label": "t:options.full"
        },
        {
          "value": "tarubi-container",
          "label": "t:options.default"
        }
      ]
    },
    {
      "type": "header",
      "content": "填充"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 36,
      "step": 4,
      "unit": "px",
      "label": "顶部",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 36,
      "step": 4,
      "unit": "px",
      "label": "底部",
      "default": 20
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "t:names.collection_list"
    }
  ]
}
{% endschema %}

{% stylesheet %}
.collection-grid{display:grid;gap:10px;grid-template-columns: repeat(4,1fr);}
{% endstylesheet %}