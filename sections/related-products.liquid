{% doc %}
{% enddoc %}

<section id="{{ section.id }}" class="related-products section-wrapper" style="padding-top:{{ section.settings.padding_top | append: 'px' }};padding-bottom:{{ section.settings.padding_bottom | append: 'px' }};">
  <div class="section {{ section.settings.container_type }}">
    <div>{{ 'accessibility.loading_product_recommendations' | t }}</div>
    {{ recommendations.performed }}
    {{ recommendations.products_count }}
    {% if recommendations.performed and recommendations.products_count > 0 %}
      {% for recommendation in recommendations.products %}
        <div>{{ recommendation.title }}</div>
        {% render 'product-card', product: recommendation %}
      {% endfor %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "t:names.related_products",
  "settings": [
    {
      "type": "select",
      "id": "container_type",
      "label": "t:settings.section_width",
      "default": "tarubi-container",
      "options": [
        {
          "value": "w-full",
          "label": "t:options.full"
        },
        {
          "value": "tarubi-container",
          "label": "t:options.default"
        }
      ]
    },
    {
      "type": "header",
      "content": "填充"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 36,
      "step": 4,
      "unit": "px",
      "label": "顶部",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 36,
      "step": 4,
      "unit": "px",
      "label": "底部",
      "default": 20
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "t:names.related_products"
    }
  ]
}
{% endschema %}