<section class="{{ section.settings.container_type }}" style="padding: 20px 0;">
  <form action="/search" method="get" role="search">
    <label>
      <input type="search" name="q" id="q" autocomplete="off" style="width: 100%;padding: 8px;" placeholder="Search"/>
    </label>
    <div style="position: absolute; right: 0; top: 0;">
      <label for="q">
        <button class="bi bi-search" type="submit"></button>
      </label>
    </div>
  </form>
  {% paginate search.results by 12 %}
    <ul style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px;">
      {% for item in search.results %}
        <li>
          {%- case item.object_type -%}
            {%- when 'product' -%}
              {% render 'product-card', product: item %}
            {%- when 'article' -%}
              {% render 'article-card', article: item %}
            {%- when 'page' -%}
              {% render 'page-card', page: item %}
          {%- endcase -%}
        </li>
      {% endfor %}
    </ul>
    {%- if paginate.pages > 1 -%}
      {%- render 'pagination', paginate: paginate -%}
    {%- endif -%}
  {% endpaginate %}
</section>

{% schema %}
{
  "name": "t:names.search",
  "settings": [
    {
      "type": "select",
      "id": "container_type",
      "label": "t:settings.section_width",
      "default": "tarubi-container",
      "options": [
        {
          "value": "w-full",
          "label": "t:options.full"
        },
        {
          "value": "tarubi-container",
          "label": "t:options.default"
        }
      ]
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "t:names.search"
    }
  ]
}
{% endschema %}