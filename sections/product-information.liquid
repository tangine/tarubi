<section id="{{ section.id }}" class="section product-information">
  <div class="product-preview">
    <ul class="product-thumbnails">
      {%- for image in product.images -%}
        <li class="product-thumbnail">
          <img src="{{ image | asset_img_url }}" alt="">
        </li>
      {%-endfor-%}
    </ul>
  </div>
  <div class="product-"></div>
  {% comment %}{{ product.title }}{% endcomment %}
  {% comment %}<ul>{% endcomment %}
    {% comment %}{%- for variant in product.variants -%}{% endcomment %}
      {% comment %}<li>{% endcomment %}
        {% comment %}<a href="{{ variant.url }}">{% endcomment %}
          {% comment %}<div>{% endcomment %}
            {% comment %}<img src="{{ variant.image }}" alt="{{ variant.title }}">{% endcomment %}
            {% comment %}<div>{{ variant.image }}</div>{% endcomment %}
          {% comment %}</div>{% endcomment %}
          {% comment %}<span>{{ variant.title }}</span>{% endcomment %}
          {% comment %}<span>{{ variant.url }}</span>{% endcomment %}
        {% comment %}</a>{% endcomment %}
{% comment %}{% endcomment %}
      {% comment %}</li>{% endcomment %}
    {% comment %}{% endfor %}{% endcomment %}
  {% comment %}</ul>{% endcomment %}

  <div id="gaussian-splats-container" data-gaussian-splats data-config='{
                "modelUrl": "./assets/butterfly.spz",
                "modelPosition": "-3,0,0",
                "modelQuaternion": "1,0,0,0",
                "cameraPosition": "0,0,5",
                "rotationSpeed": 0.01,
                "backgroundColor": "0xffffff",
                "desktopHeight": 600,
                "mobileHeight": 480,
                "enableMouseControl": true,
                "enableTouchControl": true,
                 "rotationSensitivity": 0.005,
                 "debug": true
             }'
       style="position: relative; width: 100%; height: 480px; background: transparent; z-index: 1; pointer-events: auto;">
    <canvas id="splats-canvas" style="width: 100%; height: 100%; pointer-events: auto;"></canvas>
    <div style="position: absolute; top: 10px; left: 10px; color: white; font-size: 12px;">加载 3D 高斯泼溅点...</div>
  </div>
</section>

{% schema %}
{
  "name": "Product Information",
  "settings": [],
  "blocks": [],
  "presets": [
    {
      "name": "Product Information"
    }
  ]
}
{% endschema %}